<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.helloworld.mapper.MenuMapper">

    <resultMap id="MenuResultMap" type="com.example.helloworld.entity.Menu">
        <id column="id" property="id"/>
        <result column="parent_id" property="parentId"/>
        <result column="path" property="path"/>
        <result column="name" property="name"/>
        <result column="component" property="component"/>
        <result column="redirect" property="redirect"/>
        <result column="meta_title" property="metaTitle"/>
        <result column="meta_icon" property="metaIcon"/>
        <result column="meta_hidden" property="metaHidden"/>
        <result column="meta_always_show" property="metaAlwaysShow"/>
        <result column="meta_no_cache" property="metaNoCache"/>
        <result column="meta_affix" property="metaAffix"/>
        <result column="meta_no_tags_view" property="metaNoTagsView"/>
        <result column="meta_breadcrumb" property="metaBreadcrumb"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="status" property="status"/>
    </resultMap>

    <select id="findMenusByRoleName" resultMap="MenuResultMap">
        SELECT m.*
        FROM menu m
        INNER JOIN role_menu rm ON m.id = rm.menu_id
        INNER JOIN role r ON rm.role_id = r.id
        WHERE r.role_name = #{roleName}
          AND m.status = 1
          AND r.status = 1
        ORDER BY m.parent_id, m.sort_order, m.id
    </select>

</mapper>
